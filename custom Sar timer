reate these three files in /etc/systemd/system/ 

/etc/systemd/system/mcl-sysstat-collect.service
[Unit]
# Description=system activity accounting tool
# Documentation=man:sa1(8)
After=sysstat.service

[Service]
Type=oneshot
User=root
ExecStart=/usr/lib64/sa/sa1 1 1


/etc/systemd/system/mcl-sysstat-collect.timer
### /usr/lib/systemd/system/sysstat-collect.timer
# # /usr/lib/systemd/system/sysstat-collect.timer
# # (C) 2014 Tomasz Torcz <tomek@pipebreaker.pl>
# #
# # sysstat-12.0.2 systemd unit file:
# #        Activates activity collector every 10 minutes
#
[Unit]
#Description=Run system activity accounting tool every 10 minutes

[Timer]
OnCalendar=*:00/1

[Install]
WantedBy=mcl-sysstat.service



/etc/systemd/system/mcl-sysstat.service
### /usr/lib/systemd/system/sysstat.service
# # /usr/lib/systemd/system/sysstat.service
# # (C) 2012 Peter Schiffer (pschiffe <at> redhat.com)
# #
# # sysstat-12.0.2 systemd unit file:
# #      Insert a dummy record in current daily data file.
# #      This indicates that the counters have restarted from 0.
#
 [Unit]
Description=Resets System Activity Logs
#
[Service]
Type=oneshot
RemainAfterExit=yes
User=root
ExecStart=/usr/lib64/sa/sa1 --boot

[Install]
WantedBy=multi-user.target
Also=mcl-sysstat-collect.timer
Also=sysstat-summary.timer

Check the new files are created correctly 
  systemd-analyze verify /etc/systemd/system/mcl-sysstat.service
  systemd-analyze verify /etc/systemd/system/mcl-sysstat-collect.service
  systemd-analyze verify /etc/systemd/system/mcl-sysstat-collect.timer

Stop the standard sys-stat timer 

systemctl disable sysstat-collect.timer


Enable the NEW Timer for 1 min collection 
systemctl enable mcl-sysstat-collect.timer
use systemctl list-timers to see the new timer running

